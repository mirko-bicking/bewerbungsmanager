<Window x:Class="JobApplicationTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JobApplicationTracker"
        mc:Ignorable="d"
        Title="Bewerbungsmanager"
        Height="1000"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <Style x:Key="StatusRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Beworben">
                    <Setter Property="Background" Value="#FFF9C4"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Erhalt bestätigt">
                    <Setter Property="Background" Value="#BBDEFB"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Abgelehnt">
                    <Setter Property="Background" Value="#FFCDD2"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding Status}" Value="Akzeptiert">
                    <Setter Property="Background" Value="#C8E6C9"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Linkes Formular -->
        <StackPanel Grid.Column="0">
            <TextBlock Text="Bewerbung erfassen"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,20"/>

            <TextBlock Text="Unternehmen"/>
            <TextBox x:Name="CompanyTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Position"/>
            <TextBox x:Name="PositionTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Kontaktperson"/>
            <TextBox x:Name="ContactPersonTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="E-Mail"/>
            <TextBox x:Name="ContactEmailTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Bewerbungsdatum"/>
            <DatePicker x:Name="ApplicationDatePicker"
                        Margin="0,0,0,10"/>

            <TextBlock Text="Status"/>
            <ComboBox x:Name="StatusComboBox"
                      Margin="0,0,0,10"
                      SelectedIndex="0">
                <ComboBoxItem Content="Beworben"/>
                <ComboBoxItem Content="Erhalt bestätigt"/>
                <ComboBoxItem Content="Abgelehnt"/>
                <ComboBoxItem Content="Akzeptiert"/>
            </ComboBox>

            <TextBlock Text="Notizen"/>
            <TextBox x:Name="NotesTextBox"
                     Height="100"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Margin="0,0,0,20"/>

            <Button Content="Bewerbung hinzufügen"
                    Height="35"
                    Click="AddApplicationButton_Click"/>

            <Button Content="Ausgewählte Bewerbung löschen [entf]"
                    Height="35"
                    Margin="0,10,0,0"
                    Click="DeleteApplicationButton_Click"/>

            <Button Content="Ausgewählte Bewerbung aktualisieren"
                    Height="35"
                    Margin="0,10,0,0"
                    Click="UpdateApplicationButton_Click"/>

            <Button Content="Formular leeren [esc]"
                    Height="35"
                    Margin="0,10,0,0"
                    Click="ClearFormButton_Click"/>

            <Button Content="CSV exportieren"
                    Height="35"
                    Margin="0,10,0,0"
                    Click="ExportCsvButton_Click"/>

            <!-- Status-Legende -->
            <Border Margin="0,20,0,0"
                    Padding="10"
                    BorderBrush="LightGray"
                    BorderThickness="1"
                    CornerRadius="5">
                <StackPanel>
                    <TextBlock Text="Status-Legende"
                               FontWeight="Bold"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Rectangle Width="18" Height="18" Fill="#FFF9C4" Stroke="Gray" Margin="0,0,8,0"/>
                        <TextBlock Text="Beworben"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Rectangle Width="18" Height="18" Fill="#BBDEFB" Stroke="Gray" Margin="0,0,8,0"/>
                        <TextBlock Text="Erhalt bestätigt"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Rectangle Width="18" Height="18" Fill="#FFCDD2" Stroke="Gray" Margin="0,0,8,0"/>
                        <TextBlock Text="Abgelehnt"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="18" Height="18" Fill="#C8E6C9" Stroke="Gray" Margin="0,0,8,0"/>
                        <TextBlock Text="Akzeptiert"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Rechte Seite mit Suche, Filter und Tabelle -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                Padding="10"
                Margin="0,0,0,10"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Übersicht:"
                       FontWeight="Bold"
                       Margin="0,0,20,0"/>

                        <TextBlock x:Name="TotalCountTextBlock"
                       Text="Gesamt: 0"
                       Margin="0,0,20,0"/>

                        <TextBlock x:Name="AppliedCountTextBlock"
                       Text="Beworben: 0"
                       Margin="0,0,20,0"/>

                        <TextBlock x:Name="ConfirmedCountTextBlock"
                       Text="Erhalt bestätigt: 0"
                       Margin="0,0,20,0"/>

                        <TextBlock x:Name="RejectedCountTextBlock"
                       Text="Abgelehnt: 0"
                       Margin="0,0,20,0"/>

                        <TextBlock x:Name="AcceptedCountTextBlock"
                       Text="Akzeptiert: 0"/>
                    </StackPanel>
            </Border>

            <!-- Suche und Statusfilter -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,0,0,10">
                <TextBlock Text="Suche:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <TextBox x:Name="SearchTextBox"
                         Width="250"
                         Margin="0,0,20,0"
                         TextChanged="SearchTextBox_TextChanged"/>

                <TextBlock Text="Status:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <ComboBox x:Name="StatusFilterComboBox"
                          Width="160"
                          SelectedIndex="0"
                          SelectionChanged="StatusFilterComboBox_SelectionChanged">
                    <ComboBoxItem Content="Alle"/>
                    <ComboBoxItem Content="Beworben"/>
                    <ComboBoxItem Content="Erhalt bestätigt"/>
                    <ComboBoxItem Content="Abgelehnt"/>
                    <ComboBoxItem Content="Akzeptiert"/>
                </ComboBox>
            </StackPanel>

            <!-- Tabelle -->
            <DataGrid x:Name="ApplicationsDataGrid"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="ApplicationsDataGrid_SelectionChanged"
                      HorizontalScrollBarVisibility="Auto"
                      CanUserResizeColumns="True"
                      RowStyle="{StaticResource StatusRowStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Unternehmen"
                                        Binding="{Binding CompanyName}"
                                        Width="SizeToCells"
                                        MinWidth="120"/>

                    <DataGridTextColumn Header="Position"
                                        Binding="{Binding PositionTitle}"
                                        Width="SizeToCells"
                                        MinWidth="140"/>

                    <DataGridTextColumn Header="Kontaktperson"
                                        Binding="{Binding ContactPerson}"
                                        Width="SizeToHeader"
                                        MinWidth="120"/>

                    <DataGridTextColumn Header="E-Mail"
                                        Binding="{Binding ContactEmail}"
                                        Width="SizeToCells"
                                        MinWidth="160"/>

                    <DataGridTextColumn Header="Datum"
                                        Binding="{Binding ApplicationDate, StringFormat={}{0:dd.MM.yyyy}}"
                                        Width="SizeToHeader"
                                        MinWidth="100"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="SizeToCells"
                                        MinWidth="120"/>

                    <DataGridTextColumn Header="Notizen"
                                        Binding="{Binding Notes}"
                                        Width="*"
                                        MinWidth="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>