<Window x:Class="JobApplicationTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JobApplicationTracker"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="1200">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <TextBlock Text="Bewerbungsmanager" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Unternehmen"/>
            <TextBox x:Name="CompanyTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Position"/>
            <TextBox x:Name="PositionTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Kontaktperson"/>
            <TextBox x:Name="ContactPersonTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="E-Mail"/>
            <TextBox x:Name="ContactEmailTextBox" Margin="0,0,0,10"/>

            <TextBlock Text="Status"/>
            <ComboBox x:Name="StatusComboBox" Margin="0,0,0,10" SelectedIndex="0">
                <ComboBoxItem Content="Beworben"/>
                <ComboBoxItem Content="Erhalt bestätigt"/>
                <ComboBoxItem Content="Abgelehnt"/>
                <ComboBoxItem Content="Akzeptiert"/>
            </ComboBox>

            <TextBlock Text="Notizen"/>
            <TextBox x:Name="NotesTextBox" Height="100" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20"/>

            <Button Content="Bewerbung hinzufügen" Height="35" Click="AddApplicationButton_Click"/>
        </StackPanel>

        <DataGrid x:Name="ApplicationsDataGrid"
          Grid.Column="2"
          AutoGenerateColumns="False"
          IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Unternehmen" Binding="{Binding CompanyName}" Width="*"/>
                <DataGridTextColumn Header="Position" Binding="{Binding PositionTitle}" Width="*"/>
                <DataGridTextColumn Header="Kontaktperson" Binding="{Binding ContactPerson}" Width="150"/>
                <DataGridTextColumn Header="E-Mail" Binding="{Binding ContactEmail}" Width="180"/>
                <DataGridTextColumn Header="Datum" Binding="{Binding ApplicationDate, StringFormat=d}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
